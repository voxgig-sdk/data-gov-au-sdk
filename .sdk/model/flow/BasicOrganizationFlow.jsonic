# BasicOrganizationFlow

main: kit: flow: BasicOrganizationFlow:
{
  entity: "organization",
  kind: "basic",
  name: "BasicOrganizationFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "organization_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "organization_ref01",
        srcdatavar: "organization_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-organization_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicOrganizationFlow"
}